{
  "info": {
    "name": "JobPulse API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          }
        },
        {
          "name": "Set Password (invitation)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/set-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "set-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<invitation_token>\",\n  \"password\": \"newPassword123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["api", "auth", "refresh-token"] },
            "description": "Reads the refresh token from the httpOnly cookie automatically."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Register User (admin invite)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/users/register", "host": ["{{baseUrl}}"], "path": ["api", "users", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"email\": \"jane@example.com\",\n  \"companyId\": \"<companyId>\"\n}"
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api", "users"] }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/:id", "host": ["{{baseUrl}}"], "path": ["api", "users", ":id"], "variable": [{ "key": "id", "value": "<userId>" }] }
          }
        },
        {
          "name": "Update User by ID",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/users/:id", "host": ["{{baseUrl}}"], "path": ["api", "users", ":id"], "variable": [{ "key": "id", "value": "<userId>" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\"\n}"
            }
          }
        },
        {
          "name": "Update Current User (me)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/users/me", "host": ["{{baseUrl}}"], "path": ["api", "users", "me"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\"\n}"
            }
          }
        },
        {
          "name": "Change Password (me)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/users/me/password", "host": ["{{baseUrl}}"], "path": ["api", "users", "me", "password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"oldPassword123\",\n  \"newPassword\": \"newPassword456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "Create Company",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/companies", "host": ["{{baseUrl}}"], "path": ["api", "companies"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme AS\",\n  \"orgNumber\": \"123456789\"\n}"
            }
          }
        },
        {
          "name": "Get All Companies",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/companies", "host": ["{{baseUrl}}"], "path": ["api", "companies"] }
          }
        },
        {
          "name": "Get Company by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/companies/:id", "host": ["{{baseUrl}}"], "path": ["api", "companies", ":id"], "variable": [{ "key": "id", "value": "<companyId>" }] }
          }
        },
        {
          "name": "Update Company",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/companies/:id", "host": ["{{baseUrl}}"], "path": ["api", "companies", ":id"], "variable": [{ "key": "id", "value": "<companyId>" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Group AS\"\n}"
            }
          }
        },
        {
          "name": "Delete Company",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/companies/:id", "host": ["{{baseUrl}}"], "path": ["api", "companies", ":id"], "variable": [{ "key": "id", "value": "<companyId>" }] }
          }
        },
        {
          "name": "Get Company Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/companies/:companyId/users", "host": ["{{baseUrl}}"], "path": ["api", "companies", ":companyId", "users"], "variable": [{ "key": "companyId", "value": "<companyId>" }] }
          }
        },
        {
          "name": "Add User to Company",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/companies/:companyId/users", "host": ["{{baseUrl}}"], "path": ["api", "companies", ":companyId", "users"], "variable": [{ "key": "companyId", "value": "<companyId>" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"<userId>\"\n}"
            }
          }
        },
        {
          "name": "Remove User from Company",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/companies/:companyId/users/:userId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", ":companyId", "users", ":userId"],
              "variable": [
                { "key": "companyId", "value": "<companyId>" },
                { "key": "userId", "value": "<userId>" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api", "products"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Deluxe Package\",\n  \"description\": \"Premium recruitment package\",\n  \"price\": 29000,\n  \"type\": \"package\",\n  \"channelLimit\": 7,\n  \"features\": [\"Choose up to 7 channels\", \"14 day campaign period\"]\n}"
            }
          }
        },
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products?type=package",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [{ "key": "type", "value": "package", "description": "Optional: package | channel | addon" }]
            }
          }
        },
        {
          "name": "Get Products by Type",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/type/:type",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "type", ":type"],
              "variable": [{ "key": "type", "value": "package", "description": "package | channel | addon" }]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/products/:id", "host": ["{{baseUrl}}"], "path": ["api", "products", ":id"], "variable": [{ "key": "id", "value": "<productId>" }] }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/products/:id", "host": ["{{baseUrl}}"], "path": ["api", "products", ":id"], "variable": [{ "key": "id", "value": "<productId>" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 31000\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/products/:id", "host": ["{{baseUrl}}"], "path": ["api", "products", ":id"], "variable": [{ "key": "id", "value": "<productId>" }] }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"campaignName\": \"Summer 2026\",\n  \"lineItems\": [\n    { \"type\": \"package\", \"name\": \"Deluxe Package\", \"price\": 29000 },\n    { \"type\": \"channel\", \"name\": \"LinkedIn\", \"price\": 0 },\n    { \"type\": \"addon\", \"name\": \"Video Campaign\", \"price\": 3800 }\n  ],\n  \"subtotal\": 32800,\n  \"vatRate\": 0.25,\n  \"vatAmount\": 8200,\n  \"totalAmount\": 41000,\n  \"paymentMethod\": \"invoice\",\n  \"targetAudience\": \"Experienced developers\",\n  \"additionalNotes\": \"Focus on Oslo region\"\n}"
            }
          }
        },
        {
          "name": "Create Checkout Session (Stripe)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/orders/checkout-session", "host": ["{{baseUrl}}"], "path": ["api", "orders", "checkout-session"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"campaignName\": \"Summer 2026\",\n  \"lineItems\": [\n    { \"type\": \"package\", \"name\": \"Deluxe Package\", \"price\": 29000 },\n    { \"type\": \"channel\", \"name\": \"LinkedIn\", \"price\": 0 },\n    { \"type\": \"addon\", \"name\": \"Video Campaign\", \"price\": 3800 }\n  ],\n  \"subtotal\": 32800,\n  \"vatRate\": 0.25,\n  \"vatAmount\": 8200,\n  \"totalAmount\": 41000\n}"
            }
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders/my-orders?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "my-orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get All Orders (admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Orders by Company",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/orders/company/:companyId", "host": ["{{baseUrl}}"], "path": ["api", "orders", "company", ":companyId"], "variable": [{ "key": "companyId", "value": "<companyId>" }] }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/orders/:id", "host": ["{{baseUrl}}"], "path": ["api", "orders", ":id"], "variable": [{ "key": "id", "value": "<orderId>" }] }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/orders/:id/status", "host": ["{{baseUrl}}"], "path": ["api", "orders", ":id", "status"], "variable": [{ "key": "id", "value": "<orderId>" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in-progress\"\n}"
            }
          }
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/orders/:id", "host": ["{{baseUrl}}"], "path": ["api", "orders", ":id"], "variable": [{ "key": "id", "value": "<orderId>" }] }
          }
        }
      ]
    },
    {
      "name": "Media",
      "item": [
        {
          "name": "Upload Files",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/media", "host": ["{{baseUrl}}"], "path": ["api", "media"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "files", "type": "file", "src": [] },
                { "key": "companyId", "value": "<companyId>", "type": "text" },
                { "key": "orderId", "value": "<orderId>", "type": "text", "disabled": true },
                { "key": "folderId", "value": "<folderId>", "type": "text", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Media by Company",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/media/company/:companyId?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "media", "company", ":companyId"],
              "variable": [{ "key": "companyId", "value": "<companyId>" }],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Media by Folder",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/media/folder/:folderId?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "media", "folder", ":folderId"],
              "variable": [{ "key": "folderId", "value": "<folderId>" }],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Media by Order",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/media/order/:orderId?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "media", "order", ":orderId"],
              "variable": [{ "key": "orderId", "value": "<orderId>" }],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Media by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/media/:id", "host": ["{{baseUrl}}"], "path": ["api", "media", ":id"], "variable": [{ "key": "id", "value": "<mediaId>" }] }
          }
        },
        {
          "name": "Assign Media to Folder",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/media/:id/folder", "host": ["{{baseUrl}}"], "path": ["api", "media", ":id", "folder"], "variable": [{ "key": "id", "value": "<mediaId>" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"folderId\": \"<folderId>\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Pass `folderId: null` to move to root."
          }
        },
        {
          "name": "Delete Media",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/media/:id", "host": ["{{baseUrl}}"], "path": ["api", "media", ":id"], "variable": [{ "key": "id", "value": "<mediaId>" }] }
          }
        },
        {
          "name": "S3 Connectivity Test (dev)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/media/s3-test", "host": ["{{baseUrl}}"], "path": ["api", "media", "s3-test"] }
          }
        }
      ]
    },
    {
      "name": "Folders",
      "item": [
        {
          "name": "Create Folder",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/folders", "host": ["{{baseUrl}}"], "path": ["api", "folders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Campaign Assets 2026\"\n}"
            }
          }
        },
        {
          "name": "Get Folders by Company",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/folders/company/:companyId", "host": ["{{baseUrl}}"], "path": ["api", "folders", "company", ":companyId"], "variable": [{ "key": "companyId", "value": "<companyId>" }] }
          }
        },
        {
          "name": "Rename Folder",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/folders/:id", "host": ["{{baseUrl}}"], "path": ["api", "folders", ":id"], "variable": [{ "key": "id", "value": "<folderId>" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Folder Name\"\n}"
            }
          }
        },
        {
          "name": "Delete Folder",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/folders/:id", "host": ["{{baseUrl}}"], "path": ["api", "folders", ":id"], "variable": [{ "key": "id", "value": "<folderId>" }] },
            "description": "Files inside are moved to root, not deleted."
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Stripe Webhook",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "stripe-signature", "value": "<stripe_signature>" }
            ],
            "url": { "raw": "{{baseUrl}}/api/webhooks/stripe", "host": ["{{baseUrl}}"], "path": ["api", "webhooks", "stripe"] },
            "body": {
              "mode": "raw",
              "raw": "<raw stripe event payload>"
            },
            "description": "Requires raw body + valid Stripe-Signature header. Use the Stripe CLI for local testing."
          }
        }
      ]
    }
  ]
}
